# Backend server port
PORT=8080

# MongoDB connection string
# Local example: mongodb://127.0.0.1:27017/healthhub
# Atlas example: mongodb+srv://<username>:<password>@<cluster-url>/healthhub?retryWrites=true&w=majority
DB_URL=mongodb://127.0.0.1:27017/healthhub

# Optional MongoDB driver timeout in milliseconds.
MONGO_SERVER_SELECTION_TIMEOUT_MS=10000

# JWT signing secret. Replace with a long, random value in real environments.
SECRET_KEY=replace_this_with_a_long_random_secret